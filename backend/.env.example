# ============================================================
# BITERUSH BACKEND — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/biterush

# JWT secret — any random string, keep it secret!
JWT_SECRET=your_super_secret_jwt_key_here

# Stripe secret key — from stripe.com/dashboard
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here

# Frontend URL — used by Stripe to redirect after payment
FRONTEND_URL=http://localhost:5174

# Server port (optional, defaults to 4000)
PORT=4000
